# ============================================================
# GAMZELİECZANEM — .env.example
#
# Bu dosyayı .env.local'e kopyalayın ve gerçek değerlerle doldurun.
#   cp .env.example .env.local
#
# Production (Vercel) için: Settings → Environment Variables
# altından teker teker ekleyin. "Secret" olanları mutlaka
# "Sensitive" / encrypted olarak işaretleyin.
# ============================================================

# ──────────────────────────────────────────────────────────────
# Site URL'leri
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
# Prod'da: https://gamzelieczanem.com (veya Vercel domain'i)

# ──────────────────────────────────────────────────────────────
# NextAuth — oturum imzalama secret'ı
# Terminalden üret: openssl rand -base64 32
# ──────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=

# ──────────────────────────────────────────────────────────────
# Google OAuth (hesabim/giris için)
# https://console.cloud.google.com/apis/credentials
# ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ──────────────────────────────────────────────────────────────
# Supabase (veritabanı + storage)
# Supabase Dashboard → Settings → API
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# ⚠️ service_role key SADECE server tarafında kullanılır. src/lib/supabase.js
# içinde 'server-only' guard var — client bundle'a sızmaz.

# ──────────────────────────────────────────────────────────────
# iyzico (ödeme)
# https://merchant.iyzipay.com → Entegrasyon → API Anahtarları
# ──────────────────────────────────────────────────────────────
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox.iyzipay.com
# Prod: https://api.iyzipay.com

# ──────────────────────────────────────────────────────────────
# SMTP (Gmail App Password)
# https://myaccount.google.com/apppasswords
# ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=destek.gamzelieczanem@gmail.com
SMTP_PASS=

# ──────────────────────────────────────────────────────────────
# NetGSM (SMS)
# https://www.netgsm.com.tr
# ──────────────────────────────────────────────────────────────
NETGSM_USER=
NETGSM_PASS=
NETGSM_HEADER=GAMZELIECZA

# ──────────────────────────────────────────────────────────────
# Admin paneli
# Güçlü bir şifre (min 16 karakter, karma)
# ──────────────────────────────────────────────────────────────
ADMIN_PASSWORD=

# ──────────────────────────────────────────────────────────────
# Upstash Redis (rate limit + OTP + admin brute-force)
# https://console.upstash.com → Create Database → REST API
# Boş bırakılırsa: in-memory fallback (tek instance/lokal dev için OK,
# Vercel multi-instance'ta rate limit bypass edilebilir).
# ──────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ──────────────────────────────────────────────────────────────
# Anthropic API (cilt analizi özelliği için)
# https://console.anthropic.com
# ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
